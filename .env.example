# Copy to .env and fill in from your Supabase project (Settings → API).
# These are PUBLIC-safe — the anon key is meant to ship to browsers; Row Level
# Security + the SECURITY DEFINER functions enforce all the game rules.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
